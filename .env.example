# =============================================================================
# Digital Twin UI — environment variable template
# Copy to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- API ------------------------------------------------------------------
DTUI__API__PORT=8000
DTUI__API__LOG_LEVEL=info

# --- Celery / Redis -------------------------------------------------------
DTUI__CELERY__BROKER_URL=redis://redis:6379/0
DTUI__CELERY__RESULT_BACKEND=redis://redis:6379/0

# --- MLflow ---------------------------------------------------------------
DTUI__MLFLOW__TRACKING_URI=http://mlflow:5000
DTUI__MLFLOW__EXPERIMENT_NAME=catheter_insertion

# --- Paths (IMPORTANT on a new VM) ----------------------------------------
# Absolute path on the HOST to the folder where simulation runs are written.
# Used by the MCP server to translate container paths to host paths shown to users.
# Change this to the absolute path of the runs/ folder on YOUR machine:
#   RUNS_HOST_PATH=/home/youruser/simulation-api-tool/runs
RUNS_HOST_PATH=./runs

# Absolute path on the HOST to the folder containing .feb template files.
# Copy your .feb files here BEFORE starting the stack for the first time.
# Default: ./base_configuration  (relative to the repo root, works on any machine)
# Override only if your .feb files live elsewhere:
#   BASE_CONFIG_HOST_PATH=/data/feb_files
BASE_CONFIG_HOST_PATH=./base_configuration

# --- Simulation -----------------------------------------------------------
# Path to the FEBio executable inside the worker container.
# If you bind-mount the binary, set this to the mount destination.
DTUI__SIMULATION__SIMULATOR_EXECUTABLE=febio4
FEBIO_EXECUTABLE=febio4
# FEBIO_BIN_PATH=/usr/local/bin/febio4   # host path for bind-mount

# --- ML -------------------------------------------------------------------
DTUI__ML__LEARNING_RATE=0.001
DTUI__ML__MAX_EPOCHS=500

# --- Logging --------------------------------------------------------------
DTUI__LOGGING__LEVEL=INFO
