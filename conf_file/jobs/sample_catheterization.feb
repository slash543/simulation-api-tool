		<PartList name="PrescribedDisplacement6">Part2</PartList>
		<SurfacePair name="SlidingElastic1">
			<primary>SlidingElastic1Primary</primary>
			<secondary>SlidingElastic1Secondary</secondary>
		</SurfacePair>
	</Mesh>
	<MeshDomains>
		<SolidDomain name="Part1" mat="urethra"/>
		<SolidDomain name="Part2" mat="catheter"/>
	</MeshDomains>
	<Boundary>
		<bc name="ZeroDisplacement1" node_set="@edge:ZeroDisplacement1" type="zero displacement">
			<x_dof>0</x_dof>
			<y_dof>0</y_dof>
			<z_dof>1</z_dof>
		</bc>
		<bc name="ZeroDisplacement2" node_set="@surface:ZeroDisplacement2" type="zero displacement">
			<x_dof>1</x_dof>
			<y_dof>1</y_dof>
			<z_dof>0</z_dof>
		</bc>
		<bc name="ZeroDisplacement4" node_set="ZeroDisplacement4" type="zero displacement">
			<x_dof>0</x_dof>
			<y_dof>0</y_dof>
			<z_dof>1</z_dof>
		</bc>
		<bc name="ZeroDisplacement5" node_set="@edge:ZeroDisplacement5" type="zero displacement">
			<x_dof>1</x_dof>
			<y_dof>1</y_dof>
			<z_dof>1</z_dof>
		</bc>
	</Boundary>
	<Contact>
		<contact name="SlidingElastic1" surface_pair="SlidingElastic1" type="sliding-elastic">
			<laugon>PENALTY</laugon>
			<tolerance>5e-05</tolerance>
			<gaptol>0.001</gaptol>
			<penalty>0.004</penalty>
			<auto_penalty>0</auto_penalty>
			<update_penalty>1</update_penalty>
			<two_pass>1</two_pass>
			<knmult>0</knmult>
			<search_tol>0.01</search_tol>
			<symmetric_stiffness>0</symmetric_stiffness>
			<search_radius>1</search_radius>
			<seg_up>0</seg_up>
			<tension>0</tension>
			<minaug>0</minaug>
			<maxaug>10</maxaug>
			<node_reloc>0</node_reloc>
			<fric_coeff>0.02</fric_coeff>
			<smooth_aug>1</smooth_aug>
			<flip_primary>0</flip_primary>
			<flip_secondary>0</flip_secondary>
			<shell_bottom_primary>0</shell_bottom_primary>
			<shell_bottom_secondary>0</shell_bottom_secondary>
			<offset>0</offset>
		</contact>
	</Contact>
	<Step>
		<step id="1" name="Step1">
			<Control>
				<analysis>STATIC</analysis>
				<time_steps>40</time_steps>
				<step_size>0.05</step_size>
				<plot_zero_state>0</plot_zero_state>
				<plot_range>0,-1</plot_range>
				<plot_level>PLOT_MAJOR_ITRS</plot_level>
				<output_level>OUTPUT_MAJOR_ITRS</output_level>
				<plot_stride>1</plot_stride>
				<output_stride>1</output_stride>
				<adaptor_re_solve>1</adaptor_re_solve>
				<time_stepper type="default">
					<max_retries>5</max_retries>
					<opt_iter>11</opt_iter>
					<dtmin>0</dtmin>
					<dtmax>0.1</dtmax>
					<aggressiveness>1</aggressiveness>
					<cutback>0.5</cutback>
					<dtforce>1</dtforce>
				</time_stepper>
				<solver type="solid">
					<symmetric_stiffness>preferred</symmetric_stiffness>
					<equation_scheme>staggered</equation_scheme>
					<equation_order>default</equation_order>
					<optimize_bw>0</optimize_bw>
					<lstol>0.9</lstol>
					<lsmin>0.01</lsmin>
					<lsiter>5</lsiter>
					<ls_check_jacobians>0</ls_check_jacobians>
					<max_refs>15</max_refs>
					<check_zero_diagonal>0</check_zero_diagonal>
					<zero_diagonal_tol>0</zero_diagonal_tol>
					<force_partition>0</force_partition>
					<reform_each_time_step>1</reform_each_time_step>
					<reform_augment>0</reform_augment>
					<diverge_reform>1</diverge_reform>
					<min_residual>1e-20</min_residual>
					<max_residual>0</max_residual>
					<dtol>0.001</dtol>
					<etol>0.01</etol>
					<rtol>0</rtol>
					<rhoi>-2</rhoi>
					<alpha>1</alpha>
					<beta>0.25</beta>
					<gamma>0.5</gamma>
					<logSolve>0</logSolve>
					<arc_length>0</arc_length>
					<arc_length_scale>0</arc_length_scale>
					<qn_method type="BFGS">
						<max_ups>10</max_ups>
						<max_buffer_size>0</max_buffer_size>
						<cycle_buffer>1</cycle_buffer>
						<cmax>100000</cmax>
					</qn_method>
				</solver>
			</Control>
			<Boundary>
				<bc name="event1" node_set="PrescribedDisplacement3" type="prescribed displacement">
					<dof>z</dof>
					<value lc="1">10</value>
					<relative>1</relative>
				</bc>
			</Boundary>
		</step>
		<step id="2" name="Step2">
			<Control>
				<analysis>STATIC</analysis>
				<time_steps>40</time_steps>
				<step_size>0.05</step_size>
				<plot_zero_state>0</plot_zero_state>
				<plot_range>0,-1</plot_range>
				<plot_level>PLOT_MAJOR_ITRS</plot_level>
				<output_level>OUTPUT_MAJOR_ITRS</output_level>
				<plot_stride>1</plot_stride>
				<output_stride>1</output_stride>
				<adaptor_re_solve>1</adaptor_re_solve>
				<time_stepper type="default">
					<max_retries>5</max_retries>
					<opt_iter>11</opt_iter>
					<dtmin>0</dtmin>
					<dtmax>0.1</dtmax>
					<aggressiveness>1</aggressiveness>
					<cutback>0.5</cutback>
					<dtforce>1</dtforce>
				</time_stepper>
				<solver type="solid">
					<symmetric_stiffness>preferred</symmetric_stiffness>
					<equation_scheme>staggered</equation_scheme>
					<equation_order>default</equation_order>
					<optimize_bw>0</optimize_bw>
					<lstol>0.9</lstol>
					<lsmin>0.01</lsmin>
					<lsiter>5</lsiter>
					<ls_check_jacobians>0</ls_check_jacobians>
					<max_refs>15</max_refs>
					<check_zero_diagonal>0</check_zero_diagonal>
					<zero_diagonal_tol>0</zero_diagonal_tol>
					<force_partition>0</force_partition>
					<reform_each_time_step>1</reform_each_time_step>
					<reform_augment>0</reform_augment>
					<diverge_reform>1</diverge_reform>
					<min_residual>1e-20</min_residual>
					<max_residual>0</max_residual>
					<dtol>0.001</dtol>
					<etol>0.01</etol>
					<rtol>0</rtol>
					<rhoi>-2</rhoi>
					<alpha>1</alpha>
					<beta>0.25</beta>
					<gamma>0.5</gamma>
					<logSolve>0</logSolve>
					<arc_length>0</arc_length>
					<arc_length_scale>0</arc_length_scale>
					<qn_method type="BFGS">
						<max_ups>10</max_ups>
						<max_buffer_size>0</max_buffer_size>
						<cycle_buffer>1</cycle_buffer>
						<cmax>100000</cmax>
					</qn_method>
				</solver>
			</Control>
			<Boundary>
				<bc name="event2" node_set="@part_list:PrescribedDisplacement6" type="prescribed displacement">
					<dof>z</dof>
					<value lc="1">10</value>
					<relative>1</relative>
				</bc>
			</Boundary>
		</step>
	</Step>
	<LoadData>
		<load_controller id="1" name="LC1" type="loadcurve">
			<interpolate>SMOOTH STEP</interpolate>
			<extend>CONSTANT</extend>
			<points>
				<pt>2,0</pt>
				<pt>4,1</pt>
			</points>
		</load_controller>
	</LoadData>
	<Output>
		<plotfile type="febio">
			<var type="displacement"/>
			<var type="stress"/>
			<var type="relative volume"/>
			<var type="contact pressure"/>
			<var type="contact gap"/>
			<var type="nodal contact gap"/>
			<var type="nodal contact pressure"/>
			<var type="contact traction"/>
			<var type="nodal contact traction"/>
			<var type="contact stick"/>
			<var type="contact force"/>
			<var type="contact area"/>
			<var type="contact penalty"/>
			<var type="contact status"/>
		</plotfile>
	</Output>
</febio_spec>
