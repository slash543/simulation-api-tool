# =============================================================================
# .env.librechat — LibreChat secrets + LLM configuration
#
# Copy to .env.librechat and fill in real values BEFORE starting the stack:
#   cp .env.librechat.example .env.librechat
#
# Generate secrets:
#   JWT_SECRET:         openssl rand -hex 32
#   JWT_REFRESH_SECRET: openssl rand -hex 32
#   CREDS_KEY:          openssl rand -hex 32   (must be exactly 64 hex chars)
#   CREDS_IV:           openssl rand -hex 16   (must be exactly 32 hex chars)
#   MEILI_MASTER_KEY:   openssl rand -hex 24
#
# LLM setup:
#   - Ollama model: set OLLAMA_MODEL below (default: qwen2.5:7b)
#       GPU machine (recommended):  qwen2.5:7b  (4.7 GB, fast with GPU)
#       CPU-only VM:                qwen2.5:3b  (1.9 GB, runs without GPU)
#   - Azure OpenAI: fill in the AZURE_OPENAI_* section below (optional)
#
# WARNING: Never commit the real .env.librechat to version control.
# =============================================================================

# --- Paths (IMPORTANT on a new VM) -------------------------------------------
# Absolute path on the HOST to the simulation runs/ folder.
# The MCP server uses this to tell users where their result .xplt files are.
# Change to the real absolute path on YOUR machine, e.g.:
#   RUNS_HOST_PATH=/home/youruser/simulation-api-tool/runs
RUNS_HOST_PATH=./runs

# Optional: absolute path on the HOST to a folder containing manual simulation
# results (.feb + .xplt files). Mounted read-only at /workspace/manual_sims
# inside the Jupyter container. The full_pipeline notebook reads MANUAL_SIMS_PATH
# (set automatically to /workspace/manual_sims) so no notebook edits are needed —
# just set this to your local results directory and restart the Jupyter container.
# Leave commented out if not needed.
# MANUAL_SIMS_HOST_PATH=/path/to/your/manual/simulations

# Absolute path on the HOST to the base_configuration/ folder (.feb files).
# Copy your .feb files here BEFORE running `docker compose ... up --build`.
# Default ./base_configuration works on any machine when started from the repo root.
BASE_CONFIG_HOST_PATH=./base_configuration

# Absolute path on the HOST to the surrogate data folder.
# This folder is shared between:
#   - JupyterLab (training, VTP export, CSV generation)
#   - FastAPI service (inference: CSAR, VTP prediction)
# Contents after training:
#   data/surrogate/training/     ← CSV exports from xplt-parser
#   data/surrogate/models/latest/ ← trained model artifacts
#   data/surrogate/results/      ← CSAR plots, predicted VTP files
# On a new VM use the absolute path, e.g.:
#   SURROGATE_DATA_HOST_PATH=/home/youruser/simulation-api-tool/data/surrogate
SURROGATE_DATA_HOST_PATH=./data/surrogate

# --- JupyterLab ---------------------------------------------------------------
# Access JupyterLab at http://localhost:8888?token=<JUPYTER_TOKEN>
# Change JUPYTER_PORT if 8888 is already in use.
# Generate a token:  openssl rand -hex 24
JUPYTER_PORT=8888
JUPYTER_TOKEN=CHANGE_ME_generate_with_openssl_rand_hex_24

# --- CPU resource split -------------------------------------------------------
# The worker auto-detects core count at startup (nproc) and splits resources.
# Tune with these fractions — they must sum to less than 1.0 to leave headroom
# for the OS, API, Redis, LibreChat, and MLflow.
#
# SIMULATION_CPU_FRACTION  Share of cores given to FEBio jobs (default 0.5).
# OLLAMA_NUM_THREAD        Absolute thread count for Ollama inference (default: auto).
#                          Rule of thumb: ~0.3 × nproc.  Leave blank to let
#                          Ollama auto-detect (it will use all remaining cores).
#
# Example on a 16-core machine (fraction=0.5):
#   sim_cores=8 → 1 job × 8 threads   |  Ollama: ~5 threads  |  system: ~3 cores
#
# Example on a 64-core machine (fraction=0.5):
#   sim_cores=32 → 4 jobs × 8 threads |  Ollama: ~16 threads  |  system: ~16 cores
#
# Override concurrency / OMP explicitly if you want to pin the values:
#   WORKER_CONCURRENCY=4   (skip auto-compute, use exactly 4 parallel jobs)
#   OMP_NUM_THREADS=8      (skip auto-compute, use exactly 8 threads per job)
SIMULATION_CPU_FRACTION=0.5
OLLAMA_NUM_THREAD=
WORKER_MEMORY_LIMIT=16G

# --- Ollama LLM model ---------------------------------------------------------
# GPU machine: qwen2.5:7b (default) | CPU-only VM: qwen2.5:3b
OLLAMA_MODEL=qwen2.5:7b

# --- LibreChat Server ---------------------------------------------------------
HOST=0.0.0.0
PORT=3080
DOMAIN_CLIENT=http://localhost:3080
DOMAIN_SERVER=http://localhost:3080

# --- Database -----------------------------------------------------------------
MONGO_URI=mongodb://librechat-mongodb:27017/LibreChat

# --- Secrets (REQUIRED — app will crash on startup without these) -------------
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
JWT_REFRESH_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
CREDS_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
CREDS_IV=CHANGE_ME_generate_with_openssl_rand_hex_16

# --- Search (Meilisearch) -----------------------------------------------------
MEILI_HOST=http://librechat-meilisearch:7700
MEILI_MASTER_KEY=CHANGE_ME_generate_with_openssl_rand_hex_24
SEARCH=true

# --- Agent auto-setup (optional) ---------------------------------------------
# If set, running `bash scripts/create-agent.sh` will use these credentials
# without prompting.  Also allows running the script non-interactively on VMs.
# Leave blank to be prompted each time.
LIBRECHAT_ADMIN_EMAIL=
LIBRECHAT_ADMIN_PASSWORD=

# --- Registration (set to false to allow open registration in dev) ------------
ALLOW_REGISTRATION=true
ALLOW_SOCIAL_LOGIN=false

# --- Logging ------------------------------------------------------------------
DEBUG_LOGGING=false
DEBUG_CONSOLE=false

# =============================================================================
# Azure OpenAI — primary LLM endpoint (recommended for production)
#
# How to find these values:
#   Azure Portal → Azure OpenAI resource → Keys and Endpoint
#     AZURE_OPENAI_API_KEY          → Key 1 or Key 2
#     AZURE_OPENAI_INSTANCE_NAME    → Resource name (e.g. "my-openai-resource")
#                                     NOT the full URL — just the subdomain part
#
#   Azure Portal → Azure OpenAI resource → Model deployments
#     AZURE_OPENAI_DEPLOYMENT_NAME       → your gpt-4o deployment name
#     AZURE_OPENAI_MINI_DEPLOYMENT_NAME  → your gpt-4o-mini deployment name
#                                          (leave blank if you only have one deployment)
#
#   AZURE_OPENAI_API_VERSION — use the latest stable version, e.g. 2024-02-15-preview
#   Full list: https://learn.microsoft.com/en-us/azure/ai-services/openai/reference
#
# Leave AZURE_OPENAI_API_KEY empty to disable Azure OpenAI and use Ollama only.
# =============================================================================

AZURE_OPENAI_API_KEY=
AZURE_OPENAI_INSTANCE_NAME=
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_MINI_DEPLOYMENT_NAME=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-02-15-preview
