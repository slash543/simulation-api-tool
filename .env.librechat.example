# =============================================================================
# .env.librechat — LibreChat secrets + LLM configuration
#
# Copy to .env.librechat and fill in real values BEFORE starting the stack:
#   cp .env.librechat.example .env.librechat
#
# Generate secrets:
#   JWT_SECRET:         openssl rand -hex 32
#   JWT_REFRESH_SECRET: openssl rand -hex 32
#   CREDS_KEY:          openssl rand -hex 32   (must be exactly 64 hex chars)
#   CREDS_IV:           openssl rand -hex 16   (must be exactly 32 hex chars)
#   MEILI_MASTER_KEY:   openssl rand -hex 24
#
# LLM setup:
#   - Azure OpenAI: fill in the AZURE_OPENAI_* section below (recommended)
#   - Ollama fallback: always available, no config needed
#
# WARNING: Never commit the real .env.librechat to version control.
# =============================================================================

# --- LibreChat Server ---------------------------------------------------------
HOST=0.0.0.0
PORT=3080
DOMAIN_CLIENT=http://localhost:3080
DOMAIN_SERVER=http://localhost:3080

# --- Database -----------------------------------------------------------------
MONGO_URI=mongodb://librechat-mongodb:27017/LibreChat

# --- Secrets (REQUIRED — app will crash on startup without these) -------------
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
JWT_REFRESH_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
CREDS_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
CREDS_IV=CHANGE_ME_generate_with_openssl_rand_hex_16

# --- Search (Meilisearch) -----------------------------------------------------
MEILI_HOST=http://librechat-meilisearch:7700
MEILI_MASTER_KEY=CHANGE_ME_generate_with_openssl_rand_hex_24
SEARCH=true

# --- Registration (set to false to allow open registration in dev) ------------
ALLOW_REGISTRATION=true
ALLOW_SOCIAL_LOGIN=false

# --- Logging ------------------------------------------------------------------
DEBUG_LOGGING=false
DEBUG_CONSOLE=false

# =============================================================================
# Azure OpenAI — primary LLM endpoint (recommended for production)
#
# How to find these values:
#   Azure Portal → Azure OpenAI resource → Keys and Endpoint
#     AZURE_OPENAI_API_KEY          → Key 1 or Key 2
#     AZURE_OPENAI_INSTANCE_NAME    → Resource name (e.g. "my-openai-resource")
#                                     NOT the full URL — just the subdomain part
#
#   Azure Portal → Azure OpenAI resource → Model deployments
#     AZURE_OPENAI_DEPLOYMENT_NAME       → your gpt-4o deployment name
#     AZURE_OPENAI_MINI_DEPLOYMENT_NAME  → your gpt-4o-mini deployment name
#                                          (leave blank if you only have one deployment)
#
#   AZURE_OPENAI_API_VERSION — use the latest stable version, e.g. 2024-02-15-preview
#   Full list: https://learn.microsoft.com/en-us/azure/ai-services/openai/reference
#
# Leave AZURE_OPENAI_API_KEY empty to disable Azure OpenAI and use Ollama only.
# =============================================================================

AZURE_OPENAI_API_KEY=
AZURE_OPENAI_INSTANCE_NAME=
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_MINI_DEPLOYMENT_NAME=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-02-15-preview
